 namespace OpenVDS
 {
@@ -124,6 +125,7 @@ VolumeDataAccessorBase::~VolumeDataAccessorBase()
     m_currentPage->Release();
     m_currentPage = nullptr;
   }
+  std::cout << "Volume Data Accessor base destructor" << std::endl;
   if(m_volumeDataPageAccessor)
   {
     if(m_volumeDataPageAccessor->RemoveReference() == 0)
diff --git a/src/OpenVDS/VDS/VolumeDataPageAccessorImpl.cpp b/src/OpenVDS/VDS/VolumeDataPageAccessorImpl.cpp
index 78b9c86a..d51fba06 100644
