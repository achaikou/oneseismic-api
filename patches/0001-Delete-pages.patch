 namespace OpenVDS
 {
@@ -68,12 +69,21 @@ VolumeDataPageAccessorImpl::VolumeDataPageAccessorImpl(VolumeDataAccessManagerIm
 
 VolumeDataPageAccessorImpl::~VolumeDataPageAccessorImpl()
 {
+  std::cout << "De-struc-tor!! De-struc-tor!" << std::endl;
   m_pages.clear();
   while(auto page = m_pages_lru.GetFirstItem())
   {
     m_pages_lru.Remove(page);
     delete page;
   }
+  for (auto it = m_pages.begin(); it != m_pages.end(); ++it)
+  {
+    if (it->second)
+    {
+      std::cerr << "Page not deleted" << std::endl;
+    }
+  }
+  std::cout << "Delete iteration over" << std::endl;
 
   if(m_parentVolumeDataPageAccessor)
   {
