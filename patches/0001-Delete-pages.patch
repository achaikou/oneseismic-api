 namespace OpenVDS
 {
@@ -49,6 +50,7 @@ VolumeDataAccessManagerImpl::VolumeDataAccessManagerImpl(VDS &vds)
 
 VolumeDataAccessManagerImpl::~VolumeDataAccessManagerImpl()
 {
+  std::cout << "Deleting main volume data access VolumeDataAccessManagerImpl::~VolumeDataAccessManagerImpl()" << std::endl;
   if (m_uploadErrors.errors.size())
   {
     m_vds.logger.LogWarning("VolumeDataAccessManager destructor: there where upload errors");
@@ -370,6 +372,10 @@ VolumeDataAccessManagerImpl::CreateVolumeDataPageAccessor(VolumeDataLayer const
     }
   }
 
+  std::cout << "Volume data page accessor created" << std::endl;
+  throw InvalidOperation("I want to know who birthed you and thus has power to destroy");
+
+
   VolumeDataPageAccessorImpl *pageAccessor = new VolumeDataPageAccessorImpl(this, parentVolumeDataPageAccessor, volumeDataLayer, format, useNoValue, noValue, maxPages, accessMode, m_vds.logger);
   return pageAccessor;
 }
@@ -430,6 +436,7 @@ VolumeDataAccessManagerImpl::CreateVolumeDataPageAccessorConversionParam(Dimensi
 VolumeDataPageAccessor *
 VolumeDataAccessManagerImpl::CreateVolumeDataPageAccessor(DimensionsND dimensionsND, int LOD, int channel, int maxPages, VolumeDataAccessManager::AccessMode accessMode, int chunkMetadataPageSize)
 {
+  std::cout << "Create volume data page acessor" << std::endl;
   VolumeDataLayer* volumeDataLayer;
   {
     std::unique_lock<std::mutex> lock(m_mutex);
@@ -441,6 +448,7 @@ VolumeDataAccessManagerImpl::CreateVolumeDataPageAccessor(DimensionsND dimension
 void
 VolumeDataAccessManagerImpl::DestroyVolumeDataPageAccessor(VolumeDataPageAccessor *volumeDataPageAccessor)
 {
+  std::cout << "Destroy volume data page accessor" << std::endl;
   std::unique_lock<std::mutex> lock(m_mutex);
   VolumeDataPageAccessorImpl *pageAccessor = static_cast<VolumeDataPageAccessorImpl *>(volumeDataPageAccessor);
   m_volumeDataPageAccessorList.Remove(pageAccessor);
diff --git a/src/OpenVDS/VDS/VolumeDataAccessor.cpp b/src/OpenVDS/VDS/VolumeDataAccessor.cpp
index c6b69df5..78774c01 100644
--- a/src/OpenVDS/VDS/VolumeDataAccessor.cpp
+++ b/src/OpenVDS/VDS/VolumeDataAccessor.cpp
@@ -27,6 +27,7 @@
